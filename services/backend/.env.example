# ─────────────────────────────────────────────────────────────────────────────
# Django Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# On Railway: set these in the service's Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment mode ───────────────────────────────────────────────────────────
# REQUIRED. Controls Django settings module and security behaviour.
# Use "production" on Railway, "development" locally.
DEPLOYMENT_ENV=development

# ── CORS — must match your Vercel frontend domain exactly ────────────────────
# REQUIRED in production. Add your full Vercel URL (no trailing slash).
# Without this, browser API calls may be blocked by CORS policy.
FRONTEND_URL=https://sanchaalan-saathi.vercel.app
ALLOWED_ORIGINS=                  # comma-separated additional CORS origins (optional)

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# REQUIRED. Use the direct connection on port 5432 (not the pooler on 6543).
# Found in Supabase → Project Settings → Database → Connection parameters.
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED. Must be at least 32 random characters. Change from default or the
# server will refuse to start in production (DEPLOYMENT_ENV=production).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret-min-32-chars

# ── Google Gemini (chatbot + entity extraction) ───────────────────────────────
# REQUIRED for chatbot. GEM_KEY takes precedence over GEMINI_API_KEY.
# Get from: https://aistudio.google.com/app/apikey
GEM_KEY=your-gemini-api-key-here
GEMINI_API_KEY=                   # fallback if GEM_KEY not set

# Chatbot cost controls (tokens per day per user / globally)
USER_DAILY_TOKEN_LIMIT=20000
GLOBAL_TPM_LIMIT=50000

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# REQUIRED for Google OAuth. Paste the full service account JSON as one line.
# Get from: Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Neo4j (knowledge graph) ───────────────────────────────────────────────────
# Required for graph analytics and AI matching recommendations.
# Use Neo4j AuraDB free tier: https://neo4j.com/cloud/aura/
# AuraDB URI format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Routing & location ────────────────────────────────────────────────────────
# Optional — falls back to haversine distance formula if not set.
GEOAPIFY_API_KEY=

# TTL for the in-memory volunteer location cache (seconds)
LOCATION_CACHE_TTL_SECONDS=120

# ── Dynamic reassignment ─────────────────────────────────────────────────────
ENABLE_DYNAMIC_REASSIGNMENT=true
REASSIGNMENT_MOVE_THRESHOLD_KM=0.2

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to false in production to disable the one-click guest demo accounts.
ENABLE_GUEST_MODE=true
