# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* variables are exposed to the browser AND required at build time.
# Set all of these in Vercel → Project → Settings → Environment Variables
# BEFORE deploying. Changing them after a deploy requires a redeploy.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend URL ───────────────────────────────────────────────────────────────
# Your Railway backend URL. Required at BUILD TIME (for next.config.js rewrites)
# and at RUNTIME (for WebSocket connections in useRealtimeSocket.ts).
# All HTTP API calls are proxied through Next.js — no cross-origin browser requests.
# Example: https://sanchaalan-saathi-backend.up.railway.app
NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

# ── Firebase Client SDK (public — safe to expose to browser) ─────────────────
# Found in Firebase Console → Project Settings → Your Apps → Web App → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Google Maps ───────────────────────────────────────────────────────────────
# Used for the volunteer location map. Optional — map won't load without it.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# The variables below are SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# They are available in Next.js API routes but never sent to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Admin SDK (server-side — paste full JSON as one line) ────────────
# Found in Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Gemini AI (server-side — for task generation API route) ──────────────────
GEM_KEY=

# ── Database (server-side — used only in Next.js API routes if applicable) ───
DATABASE_URL=
